generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMINISTRADOR
  ENFERMERA
  CONSULTA
}

enum Turno {
  MANANA
  TARDE
  NOCHE
}

enum TipoControl {
  RUTINARIO
  URGENTE
  SEGUIMIENTO
  INGRESO
  PERIODICO
}

enum PresentacionMedicamento {
  COMPRIMIDO
  JERINGA
  AMPOLLA
  JARABE
  CREMA
  CAPSULA
}

enum EstadoRemision {
  PENDIENTE
  EN_CURSO
  FINALIZADO
}

enum TipoRemision {
  ESPECIALISTA
  EPS
  INCAPACIDAD
  EXAMEN_EXTERNO
  OTRO
}

model RoleEntity {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique @db.VarChar(50)
  users     User[]

  @@map("roles")
}

model User {
  id              Int       @id @default(autoincrement())
  usuario         String    @unique @db.VarChar(255)
  passwordHash    String    @db.VarChar(255)
  nombre          String    @db.VarChar(255)
  apellido        String    @db.VarChar(255)
  matricula       String    @unique @db.VarChar(100)
  turno           Turno
  activo          Boolean   @default(true)
  roleId          Int       @default(2)
  role            RoleEntity @relation(fields: [roleId], references: [id])
  controles       Control[]
  remisiones      Remision[]
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Paciente {
  id                Int       @id @default(autoincrement())
  dni               String    @unique @db.VarChar(20)
  nombre            String    @db.VarChar(255)
  apellido          String    @db.VarChar(255)
  fechaNacimiento   DateTime? @map("fecha_nacimiento")
  departamento      String?   @db.VarChar(255)
  puesto            String?   @db.VarChar(255)
  fechaIngreso      DateTime? @map("fecha_ingreso")
  alergias          String?   @db.Text
  contactoEmergencia String?  @db.VarChar(255) @map("contacto_emergencia")
  telefono          String?   @db.VarChar(50)
  email             String?   @db.VarChar(255)
  activo            Boolean   @default(true)
  controles         Control[]
  recetas           Receta[]
  tratamientos      Tratamiento[]
  remisiones        Remision[]
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("pacientes")
}

model Control {
  id                Int             @id @default(autoincrement())
  pacienteId        Int             @map("paciente_id")
  paciente          Paciente        @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  enfermeraId       Int             @map("enfermera_id")
  enfermera         User            @relation(fields: [enfermeraId], references: [id], onDelete: Restrict)
  fecha             DateTime
  tipo              TipoControl
  presionSistolica  Int?            @map("presion_sistolica")
  presionDiastolica Int?            @map("presion_diastolica")
  temperatura       Decimal?        @db.Decimal(4, 1)
  pulso             Int?
  saturacionO2      Int?            @map("saturacion_o2")
  peso              Decimal?        @db.Decimal(5, 2)
  talla             Decimal?        @db.Decimal(5, 2)
  motivo            String?         @db.VarChar(255)
  observaciones     String?         @db.Text
  recetas           Receta[]
  tratamientos      Tratamiento[]
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@index([pacienteId, fecha], map: "idx_controles_paciente_fecha")
  @@index([fecha], map: "idx_controles_fecha")
  @@map("controles")
}

model Medicamento {
  id            Int                  @id @default(autoincrement())
  nombre        String               @db.VarChar(255)
  presentacion  PresentacionMedicamento
  unidad        String               @db.VarChar(50)
  descripcion   String?              @db.Text
  stock         Int                  @default(0)
  stockMinimo   Int                  @default(10) @map("stock_minimo")
  activo        Boolean              @default(true)
  recetas       Receta[]
  tratamientos  Tratamiento[]
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  @@map("medicamentos")
}

model Receta {
  id              Int          @id @default(autoincrement())
  pacienteId      Int          @map("paciente_id")
  paciente        Paciente     @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  controlId       Int?         @map("control_id")
  control         Control?     @relation(fields: [controlId], references: [id], onDelete: SetNull)
  medicamentoId   Int          @map("medicamento_id")
  medicamento     Medicamento  @relation(fields: [medicamentoId], references: [id], onDelete: Restrict)
  dosis           String       @db.VarChar(100)
  frecuencia      String       @db.VarChar(100)
  duracionDias    Int          @map("duracion_dias")
  fechaInicio     DateTime     @map("fecha_inicio")
  fechaFin        DateTime     @map("fecha_fin")
  medico          String       @db.VarChar(150)
  observaciones   String?      @db.Text
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@index([pacienteId], map: "idx_recetas_paciente")
  @@index([fechaInicio, fechaFin], map: "idx_recetas_fechas")
  @@index([medicamentoId], map: "idx_recetas_medicamento")
  @@map("recetas")
}

model Tratamiento {
  id              Int          @id @default(autoincrement())
  pacienteId      Int          @map("paciente_id")
  paciente        Paciente     @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  controlId       Int?         @map("control_id")
  control         Control?     @relation(fields: [controlId], references: [id], onDelete: SetNull)
  medicamentoId   Int          @map("medicamento_id")
  medicamento     Medicamento  @relation(fields: [medicamentoId], references: [id], onDelete: Restrict)
  dosis           String       @db.VarChar(100)
  frecuencia      String       @db.VarChar(100)
  duracionDias    Int          @map("duracion_dias")
  fechaInicio     DateTime     @map("fecha_inicio")
  fechaFin        DateTime     @map("fecha_fin")
  observaciones   String?      @db.Text
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@index([pacienteId], map: "idx_tratamientos_paciente")
  @@map("tratamientos")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?     @map("user_id")
  usuario    String?  @db.VarChar(255)
  rol        String?  @db.VarChar(50)
  metodo     String   @db.VarChar(10)
  ruta       String   @db.VarChar(500)
  statusCode Int      @map("status_code")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId], map: "idx_audit_user")
  @@index([createdAt], map: "idx_audit_fecha")
  @@map("audit_logs")
}

model Remision {
  id              Int           @id @default(autoincrement())
  pacienteId      Int           @map("paciente_id")
  paciente        Paciente      @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  tipo            TipoRemision
  destino         String        @db.VarChar(255)
  motivo          String        @db.Text
  diagnostico     String?       @db.Text
  estado          EstadoRemision @default(PENDIENTE)
  fechaRemision   DateTime      @map("fecha_remision")
  fechaRespuesta  DateTime?     @map("fecha_respuesta")
  observaciones   String?       @db.Text
  enfermeraId     Int           @map("enfermera_id")
  enfermera       User          @relation(fields: [enfermeraId], references: [id], onDelete: Restrict)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([pacienteId], map: "idx_remisiones_paciente")
  @@index([estado], map: "idx_remisiones_estado")
  @@index([fechaRemision], map: "idx_remisiones_fecha")
  @@map("remisiones")
}
